<!DOCTYPE html>
<html lang="en" dir="ltr" id="htmlTag">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>OnspotMarket | Cloud Dashboard</title>
    <!-- Supabase SDK -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #f8fafc; color: #1e293b; overflow-x: hidden; }
        .tab-content { display: none; }
        .tab-content.active { display: block; animation: fadeInUp 0.4s ease; }
        
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .sidebar-item.active { background: #6366f1; color: white; box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3); }
        .mobile-nav-item.active { color: #6366f1; }
        
        .custom-scroll::-webkit-scrollbar { width: 6px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }

        #reader { border: none !important; border-radius: 24px; overflow: hidden; background: #f1f5f9; }
        
        @media (min-width: 1024px) {
            .pos-grid { display: grid; grid-template-columns: 1fr 450px; gap: 2rem; }
        }
        @media print { .no-print { display: none !important; } }
    </style>
</head>
<body>

    <!-- LOGIN PANEL -->
    <div id="loginOverlay" class="fixed inset-0 bg-slate-900 z-[1000] flex items-center justify-center p-6">
        <div class="bg-white rounded-[2.5rem] p-10 w-full max-w-md shadow-2xl">
            <div class="text-center mb-10">
                <div class="w-20 h-20 bg-indigo-600 rounded-3xl flex items-center justify-center mx-auto mb-4 shadow-xl">
                    <i class="fas fa-shop text-white text-3xl"></i>
                </div>
                <h1 class="text-3xl font-black text-slate-900 tracking-tight">OnspotMarket</h1>
                <p class="text-slate-400 font-bold text-xs uppercase tracking-widest mt-2">Cloud Terminal</p>
            </div>
            <div class="space-y-4">
                <input id="uIn" type="text" placeholder="Username" class="w-full bg-slate-50 border border-slate-200 p-5 rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500 transition">
                <input id="pIn" type="password" placeholder="Password" class="w-full bg-slate-50 border border-slate-200 p-5 rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500 transition">
                <button onclick="handleLogin()" class="w-full bg-indigo-600 text-white py-5 rounded-2xl font-black text-lg hover:bg-indigo-700 active:scale-95 transition-all shadow-lg">
                    Login to System
                </button>
            </div>
        </div>
    </div>

    <!-- MAIN APP -->
    <div id="app" class="hidden min-h-screen flex flex-col lg:flex-row">
        
        <!-- SIDEBAR (PC) -->
        <aside class="no-print hidden lg:flex w-72 bg-white border-r border-slate-200 flex-col sticky top-0 h-screen z-50">
            <div class="p-8 font-black text-2xl tracking-tighter flex items-center gap-3 text-indigo-600">
                <i class="fas fa-circle-nodes"></i> OnspotMarket
            </div>
            <nav class="flex-1 px-4 space-y-2">
                <button onclick="setTab('pos')" class="sidebar-item active w-full flex items-center gap-4 p-4 rounded-2xl font-bold text-slate-500 transition-all" data-tab="pos">
                    <i class="fas fa-cash-register"></i> Terminal
                </button>
                <button onclick="setTab('inv')" class="sidebar-item w-full flex items-center gap-4 p-4 rounded-2xl font-bold text-slate-500 transition-all" data-tab="inv">
                    <i class="fas fa-boxes-stacked"></i> Inventory
                </button>
                <button id="ownerNav" onclick="setTab('rep')" class="sidebar-item w-full flex items-center gap-4 p-4 rounded-2xl font-bold text-slate-500 transition-all" data-tab="rep">
                    <i class="fas fa-chart-pie"></i> Analytics
                </button>
                <button onclick="setTab('cash')" class="sidebar-item w-full flex items-center gap-4 p-4 rounded-2xl font-bold text-slate-500 transition-all" data-tab="cash">
                    <i class="fas fa-vault"></i> Cash Box
                </button>
            </nav>
            <div class="p-6 m-4 bg-slate-50 rounded-3xl flex items-center gap-3">
                <div id="avatar" class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white font-bold">A</div>
                <div class="flex-1 overflow-hidden">
                    <p id="nameDisplay" class="text-sm font-bold truncate">User</p>
                    <p id="roleDisplay" class="text-[10px] font-black text-slate-400 uppercase">Role</p>
                </div>
                <button onclick="location.reload()" class="text-red-400"><i class="fas fa-power-off"></i></button>
            </div>
        </aside>

        <!-- BOTTOM NAV (MOBILE) -->
        <nav class="lg:hidden fixed bottom-0 left-0 right-0 bg-white border-t h-20 flex items-center justify-around z-[100] shadow-2xl px-4">
            <button onclick="setTab('pos')" class="mobile-nav-item active flex flex-col items-center gap-1 flex-1" data-tab="pos"><i class="fas fa-qrcode text-xl"></i><span class="text-[9px] font-black">POS</span></button>
            <button onclick="setTab('inv')" class="mobile-nav-item flex flex-col items-center gap-1 flex-1" data-tab="inv"><i class="fas fa-box text-xl"></i><span class="text-[9px] font-black">STOCK</span></button>
            <button id="mRepNav" onclick="setTab('rep')" class="mobile-nav-item flex flex-col items-center gap-1 flex-1" data-tab="rep"><i class="fas fa-chart-line text-xl"></i><span class="text-[9px] font-black">STATS</span></button>
            <button onclick="setTab('cash')" class="mobile-nav-item flex flex-col items-center gap-1 flex-1" data-tab="cash"><i class="fas fa-coins text-xl"></i><span class="text-[9px] font-black">CASH</span></button>
        </nav>

        <!-- MAIN VIEWPORT -->
        <main class="flex-1 flex flex-col min-w-0 h-screen overflow-hidden">
            <header class="h-16 lg:h-20 bg-white border-b border-slate-200 px-6 lg:px-10 flex items-center justify-between sticky top-0 z-40 shrink-0">
                <h2 id="viewTitle" class="text-xl font-black text-slate-800">Terminal</h2>
                <div id="clock" class="text-xs font-black text-slate-400 bg-slate-50 px-3 py-1.5 rounded-lg"></div>
            </header>

            <div class="flex-1 overflow-y-auto p-4 lg:p-10 pb-24 lg:pb-10 custom-scroll">
                
                <!-- TERMINAL VIEW -->
                <section id="pos" class="tab-content active">
                    <div class="pos-grid">
                        <div class="space-y-6">
                            <div class="bg-white p-6 rounded-[2rem] border border-slate-200 shadow-sm">
                                <div id="reader" class="w-full mb-4 aspect-video"></div>
                                <button onclick="initScanner()" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-black flex items-center justify-center gap-3 hover:bg-black transition-all">
                                    <i class="fas fa-camera"></i> Start Mobile Scanner
                                </button>
                            </div>
                            <div class="bg-white p-6 rounded-[2rem] border border-slate-200">
                                <input type="text" id="posSearch" onkeyup="findProduct(this.value)" placeholder="Search by name or code..." class="w-full bg-slate-50 border-none p-5 rounded-2xl outline-none focus:ring-2 focus:ring-indigo-500">
                                <div id="posResults" class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-64 overflow-y-auto no-scrollbar"></div>
                            </div>
                        </div>

                        <!-- CART -->
                        <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-2xl flex flex-col h-[650px] lg:sticky lg:top-0">
                            <div class="p-8 border-b flex justify-between items-center bg-slate-50/50 rounded-t-[2.5rem]">
                                <h3 class="font-black text-slate-800">Order Summary</h3>
                                <button onclick="cart=[];renderCart()" class="text-[10px] font-black text-red-500 uppercase px-3 py-1 bg-red-50 rounded-lg">Reset</button>
                            </div>
                            <div id="cartList" class="flex-1 overflow-y-auto p-6 space-y-3 custom-scroll"></div>
                            <div class="p-8 bg-white border-t border-slate-100 rounded-b-[2.5rem] space-y-6">
                                <div class="flex justify-between items-end">
                                    <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Grand Total</span>
                                    <span id="cartSum" class="text-4xl font-black text-slate-900">$0.00</span>
                                </div>
                                <button onclick="completeOrder()" id="payBtn" class="w-full bg-emerald-500 text-white py-5 rounded-2xl font-black text-xl shadow-xl active:scale-95 transition-all">
                                    COMPLETE SALE
                                </button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- INVENTORY -->
                <section id="inv" class="tab-content">
                    <div class="flex justify-between items-center mb-8 bg-white p-6 rounded-[2rem] border border-slate-200">
                        <h3 class="text-2xl font-black">Inventory Control</h3>
                        <button id="addBtn" onclick="toggleModal('addModal', true)" class="bg-indigo-600 text-white px-8 py-4 rounded-2xl font-bold shadow-lg shadow-indigo-100 hover:bg-indigo-700 transition">+ New Product</button>
                    </div>
                    <div id="invGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
                </section>

                <!-- ANALYTICS -->
                <section id="rep" class="tab-content">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
                        <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm">
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">Total Sales</p>
                            <h4 id="repSales" class="text-4xl font-black text-slate-900">$0.00</h4>
                        </div>
                        <div class="bg-indigo-600 p-8 rounded-[2.5rem] text-white shadow-xl shadow-indigo-100">
                            <p class="text-[10px] font-black text-indigo-200 uppercase tracking-widest mb-2">Net Profit</p>
                            <h4 id="repProfit" class="text-4xl font-black">$0.00</h4>
                        </div>
                    </div>
                    <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200">
                        <h4 class="font-black mb-6">Recent Live Transactions</h4>
                        <div id="salesHistory" class="space-y-4"></div>
                    </div>
                </section>

                <!-- CASH BOX -->
                <section id="cash" class="tab-content">
                    <div class="max-w-md mx-auto text-center space-y-6 pt-10">
                        <div class="bg-slate-900 p-16 rounded-[3rem] text-white shadow-2xl relative overflow-hidden">
                            <p class="text-indigo-400 font-black text-[10px] tracking-widest mb-4 uppercase">Drawer Balance</p>
                            <h2 id="cashMain" class="text-6xl font-black">$0.00</h2>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <button onclick="toggleModal('cashModal', true, 'in')" class="bg-white p-8 rounded-3xl border border-slate-200 font-black text-xs hover:bg-slate-50 transition">
                                <i class="fas fa-plus text-emerald-500 block mb-2 text-2xl"></i> DEPOSIT
                            </button>
                            <button onclick="toggleModal('cashModal', true, 'out')" class="bg-white p-8 rounded-3xl border border-slate-200 font-black text-xs hover:bg-slate-50 transition">
                                <i class="fas fa-minus text-rose-500 block mb-2 text-2xl"></i> EXPENSE
                            </button>
                        </div>
                    </div>
                </section>
            </div>
        </main>
    </div>

    <!-- ADD PRODUCT MODAL -->
    <div id="addModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[200] hidden items-center justify-center p-6">
        <div class="bg-white w-full max-w-lg rounded-[2.5rem] p-10 shadow-2xl">
            <h3 class="text-2xl font-black mb-8 text-slate-800">New Product Entry</h3>
            <div class="space-y-4">
                <input id="prodName" type="text" placeholder="Name" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none">
                <input id="prodBar" type="text" placeholder="Barcode Code" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl font-mono text-indigo-600 outline-none">
                <div class="grid grid-cols-2 gap-4">
                    <input id="prodCost" type="number" step="0.01" placeholder="Cost ($)" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none">
                    <input id="prodPrice" type="number" step="0.01" placeholder="Selling ($)" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none">
                </div>
                <input id="prodQty" type="number" placeholder="Initial Stock" class="w-full bg-slate-50 border border-slate-200 p-4 rounded-2xl outline-none">
                <div class="flex gap-4 pt-6">
                    <button onclick="saveToCloud()" id="saveBtn" class="flex-[2] bg-indigo-600 text-white py-5 rounded-2xl font-black active:scale-95 transition-all shadow-lg">SAVE PRODUCT</button>
                    <button onclick="toggleModal('addModal', false)" class="flex-1 bg-slate-100 text-slate-400 py-5 rounded-2xl font-black">CANCEL</button>
                </div>
            </div>
        </div>
    </div>

    <!-- CASH MODAL -->
    <div id="cashModal" class="fixed inset-0 bg-slate-900/60 z-[200] hidden items-center justify-center p-6">
        <div class="bg-white w-full max-w-sm rounded-[2.5rem] p-10 shadow-2xl">
            <h3 id="cashModalTitle" class="text-xl font-black mb-6">Cash Action</h3>
            <input id="cashAmt" type="number" placeholder="$0.00" class="w-full bg-slate-50 p-6 rounded-2xl mb-6 text-center text-4xl font-black outline-none border border-slate-100">
            <button id="cashBtn" onclick="submitCashAdjust()" class="w-full py-5 rounded-2xl font-black text-white shadow-xl active:scale-95 transition-all">CONFIRM</button>
            <button onclick="toggleModal('cashModal', false)" class="w-full mt-4 text-slate-400 font-bold text-xs uppercase text-center">Close</button>
        </div>
    </div>

    <script>
        // --- SUPABASE CONFIG ---
        const SUPABASE_URL = "https://vmgsedyschthwheiuimo.supabase.co";
        const SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZtZ3NlZHlzY2h0aHdoZWl1aW1vIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4MDU0NzAsImV4cCI6MjA5MDM4MTQ3MH0.GJi9puow1ZSoO1znQWh-Jxtoo4tgt8P6ydDT_ZD-pkU";
        const _cloud = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        let user = null;
        let inventory = [];
        let cart = [];
        let cashType = 'in';

        // --- AUTH ---
        function handleLogin() {
            const u = document.getElementById('uIn').value;
            const p = document.getElementById('pIn').value;
            if((u === 'admin' && p === '123') || (u === 'staff' && p === '123')) {
                user = { name: u === 'admin' ? 'Owner Admin' : 'Staff Cashier', role: u === 'admin' ? 'owner' : 'cashier' };
                document.getElementById('loginOverlay').classList.add('hidden');
                document.getElementById('app').classList.remove('hidden');
                bootstrapApp();
            }
        }

        async function bootstrapApp() {
            document.getElementById('nameDisplay').innerText = user.name;
            document.getElementById('roleDisplay').innerText = user.role;
            document.getElementById('avatar').innerText = user.name[0];
            
            if(user.role === 'cashier') {
                ['ownerNav', 'mRepNav', 'addBtn'].forEach(id => { if(document.getElementById(id)) document.getElementById(id).style.display = 'none'; });
            }

            await syncAll();
            setInterval(() => { document.getElementById('clock').innerText = new Date().toLocaleString(); }, 1000);

            // Subscribe to cloud changes
            _cloud.channel('realtime_pos')
                .on('postgres_changes', { event: '*', schema: 'public', table: 'inventory' }, syncAll)
                .on('postgres_changes', { event: '*', schema: 'public', table: 'sales' }, syncAll)
                .on('postgres_changes', { event: '*', schema: 'public', table: 'cash_transactions' }, syncAll)
                .subscribe();
        }

        async function syncAll() {
            const { data: inv } = await _cloud.from('inventory').select('*').order('name');
            inventory = inv || [];

            const { data: sls } = await _cloud.from('sales').select('*').order('created_at', { ascending: false });
            const { data: cashData } = await _cloud.from('cash_transactions').select('amount, type');

            let totalCash = 0;
            cashData?.forEach(t => totalCash += (t.type === 'in' ? parseFloat(t.amount) : -parseFloat(t.amount)));

            renderInventory(inventory);
            renderAnalytics(sls || [], totalCash);
        }

        // --- INVENTORY LOGIC ---
        function renderInventory(data) {
            document.getElementById('invGrid').innerHTML = data.map(i => `
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-200 shadow-sm flex justify-between items-center hover:border-indigo-400 transition-all">
                    <div>
                        <p class="font-bold text-slate-800 text-lg">${i.name}</p>
                        <p class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">${i.barcode}</p>
                        <p class="text-2xl font-black mt-2">$${i.price.toFixed(2)}</p>
                    </div>
                    <div class="text-right">
                        <span class="px-4 py-2 rounded-xl text-[10px] font-black ${i.qty < 10 ? 'bg-rose-500 text-white' : 'bg-emerald-100 text-emerald-600'}">
                            ${i.qty} Units
                        </span>
                        ${user.role === 'owner' ? `<button onclick="deleteProd('${i.id}')" class="block mt-6 text-slate-300 hover:text-rose-500 ml-auto transition"><i class="fas fa-trash-alt"></i></button>` : ''}
                    </div>
                </div>
            `).join('');
        }

        async function saveToCloud() {
            const n = document.getElementById('prodName').value;
            const b = document.getElementById('prodBar').value;
            const c = parseFloat(document.getElementById('prodCost').value);
            const p = parseFloat(document.getElementById('prodPrice').value);
            const q = parseInt(document.getElementById('prodQty').value);

            if(!n || !b || isNaN(p) || isNaN(q)) return alert("Please fill in all product fields correctly.");

            const saveBtn = document.getElementById('saveBtn');
            saveBtn.innerText = "UPLOADING...";
            saveBtn.disabled = true;

            const { error } = await _cloud.from('inventory').insert([{ 
                name: n, 
                barcode: b, 
                cost: c, 
                price: p, 
                qty: q 
            }]);

            if (error) {
                alert("Cloud Error: " + error.message);
            } else {
                toggleModal('addModal', false);
                document.getElementById('prodName').value = '';
                document.getElementById('prodBar').value = '';
                document.getElementById('prodCost').value = '';
                document.getElementById('prodPrice').value = '';
                document.getElementById('prodQty').value = '';
                alert("Product saved successfully to Cloud!");
            }
            
            saveBtn.innerText = "SAVE TO CLOUD";
            saveBtn.disabled = false;
        }

        async function deleteProd(id) {
            if(confirm("Permanently delete product?")) await _cloud.from('inventory').delete().eq('id', id);
        }

        // --- TERMINAL LOGIC ---
        function findProduct(val) {
            const box = document.getElementById('posResults');
            if(!val) { box.innerHTML = ''; return; }
            const matches = inventory.filter(i => i.name.toLowerCase().includes(val.toLowerCase()) || i.barcode.includes(val));
            box.innerHTML = matches.map(i => `
                <div onclick="addCart('${i.barcode}')" class="bg-white p-5 rounded-2xl border border-slate-200 flex justify-between items-center cursor-pointer active:scale-95 transition-all hover:border-indigo-400 shadow-sm">
                    <span class="font-bold text-sm text-slate-700">${i.name}</span>
                    <span class="font-black text-indigo-600">$${i.price.toFixed(2)}</span>
                </div>
            `).join('');
        }

        function addCart(code) {
            const p = inventory.find(i => i.barcode === code);
            if(!p || p.qty <= 0) return alert("Out of stock!");
            cart.push({...p});
            renderCart();
            document.getElementById('posSearch').value = '';
            document.getElementById('posResults').innerHTML = '';
        }

        function renderCart() {
            const box = document.getElementById('cartList');
            let total = 0;
            box.innerHTML = cart.length ? cart.map((i, idx) => {
                total += i.price;
                return `
                <div class="flex justify-between items-center bg-slate-50 p-4 rounded-2xl border border-slate-100 animate-slide-up">
                    <div class="flex-1 min-w-0 pr-4">
                        <p class="font-bold text-xs truncate">${i.name}</p>
                        <p class="text-[10px] font-black text-indigo-500">$${i.price.toFixed(2)}</p>
                    </div>
                    <button onclick="cart.splice(${idx},1);renderCart()" class="text-slate-300 hover:text-rose-500 transition"><i class="fas fa-circle-xmark text-xl"></i></button>
                </div>`;
            }).join('') : `<div class="text-center py-24 opacity-20"><i class="fas fa-cart-arrow-down text-6xl"></i></div>`;
            document.getElementById('cartSum').innerText = `$${total.toFixed(2)}`;
        }

        async function completeOrder() {
            if(!cart.length) return;
            const btn = document.getElementById('payBtn');
            btn.innerText = "UPLOADING...";
            btn.disabled = true;

            const total = cart.reduce((s, i) => s + i.price, 0);
            const cost = cart.reduce((s, i) => s + i.cost, 0);

            await _cloud.from('sales').insert([{ items: cart, total, cost, method: 'cash' }]);
            for(let item of cart) {
                await _cloud.from('inventory').update({ qty: item.qty - 1 }).eq('id', item.id);
            }
            await _cloud.from('cash_transactions').insert([{ amount: total, type: 'in', note: 'Sale' }]);

            cart = [];
            renderCart();
            btn.innerText = "COMPLETE SALE";
            btn.disabled = false;
            alert("Order Processed!");
        }

        // --- ANALYTICS & CASH ---
        function renderAnalytics(sls, cash) {
            let rev = 0, cost = 0;
            sls.forEach(s => { rev += s.total; cost += s.cost; });
            document.getElementById('repSales').innerText = `$${rev.toFixed(2)}`;
            document.getElementById('repProfit').innerText = `$${(rev - cost).toFixed(2)}`;
            document.getElementById('cashMain').innerText = `$${cash.toFixed(2)}`;

            document.getElementById('salesHistory').innerHTML = sls.slice(0, 5).map(s => `
                <div class="flex justify-between p-4 bg-slate-50 rounded-2xl border">
                    <span class="text-xs font-bold">${new Date(s.created_at).toLocaleTimeString()}</span>
                    <span class="font-black text-emerald-600">+$${s.total.toFixed(2)}</span>
                </div>
            `).join('');
        }

        async function submitCashAdjust() {
            const amt = parseFloat(document.getElementById('cashAmt').value);
            if(!amt) return;
            await _cloud.from('cash_transactions').insert([{ amount: amt, type: cashType, note: 'Manual Adjustment' }]);
            toggleModal('cashModal', false);
            document.getElementById('cashAmt').value = '';
        }

        // --- TAB HELPERS ---
        function setTab(t) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.sidebar-item, .mobile-nav-item').forEach(b => b.classList.remove('active'));
            document.getElementById(t).classList.add('active');
            document.querySelectorAll(`[data-tab="${t}"]`).forEach(b => b.classList.add('active'));
            document.getElementById('viewTitle').innerText = t.charAt(0).toUpperCase() + t.slice(1);
        }

        function toggleModal(id, show, type = null) {
            const m = document.getElementById(id);
            m.classList.toggle('hidden', !show);
            m.classList.toggle('flex', show);
            if(type) {
                cashType = type;
                document.getElementById('cashModalTitle').innerText = type === 'in' ? 'Deposit Cash' : 'Withdraw Cash';
                document.getElementById('cashBtn').className = `w-full py-5 rounded-2xl font-black text-white ${type === 'in' ? 'bg-emerald-500' : 'bg-rose-500'}`;
            }
        }

        let scanner;
        function initScanner() {
            scanner = new Html5Qrcode("reader");
            scanner.start({ facingMode: "environment" }, { fps: 10, qrbox: 250 }, (txt) => addCart(txt));
        }
    </script>
</body>
</html>
